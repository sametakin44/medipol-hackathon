# AYNA — Ortam değişkenleri örneği.
# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# .env asla commit edilmez (bkz. .gitignore).

# OpenRouter API anahtarı — https://openrouter.ai/keys adresinden alın.
OPENROUTER_API_KEY=

# (Opsiyonel) OpenRouter, "X-Title" header'ı için uygulama adı bekler.
OPENROUTER_APP_NAME=AYNA

# (Opsiyonel) OpenRouter, "HTTP-Referer" header'ı için uygulama URL'i bekler.
OPENROUTER_APP_URL=http://localhost:5173

# (Opsiyonel) Express sunucusunun portu. Varsayılan 3001.
PORT=3001
